DATABASE_URL="postgresql://user:password@localhost:5432/rakium_be?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRATION="7d"
PORT=3000
CORS_ORIGINS="http://localhost:4200,http://localhost:5173,http://localhost:3000"

# Optional: storage uploads
STORAGE_PROVIDER="backblaze"

# Backblaze B2 uploads
BACKBLAZE_ACCESS_KEY_ID=""
BACKBLAZE_SECRET_ACCESS_KEY=""
BACKBLAZE_BUCKET_NAME=""

# Google Cloud Storage uploads
GCS_PROJECT_ID=""
GCS_BUCKET_NAME=""
# Prefer injecting the service account JSON as one escaped single-line secret.
GCS_SERVICE_ACCOUNT_JSON=""
# Alternative for local/server file-based auth.
GOOGLE_APPLICATION_CREDENTIALS=""
