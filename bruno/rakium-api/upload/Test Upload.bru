meta {
  name: Test Upload
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/upload/test
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:multipart-form {
  file: @file(test-image.png)
}

vars:pre-request {
  baseUrl: https://rakium-be-production.up.railway.app
  authToken: bruno.getEnvironmentVar("authToken")
}

tests {
  test("Status code is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  
  test("File uploaded successfully", function() {
    expect(res.getBody().url).to.be.a('string');
    expect(res.getBody().filename).to.be.a('string');
    expect(res.getBody().size).to.be.a('number');
  });
}
